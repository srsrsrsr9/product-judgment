---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CHAPTERS } from '../../data/chapters';
---

<BaseLayout title="The Book — The Garage Band Problem" activePage="book">
  <div class="page-enter">
    <div class="section">
      <div class="section-header">
        <span class="section-num">01</span>
        <h2 class="section-title">The Book</h2>
      </div>
      <div class="book-intro">
        <p>A practical guide for builders who can ship code but need a system for deciding <em>what</em> to build and <em>why</em>. Ten chapters that bridge the gap between having AI superpowers and building something people actually need.</p>
      </div>
      <div class="chapter-list">
        {CHAPTERS.map((ch) => (
          <a class="chapter-item" href={`${import.meta.env.BASE_URL}book/${ch.slug}/`}>
            <div class="ch-num">{String(ch.num).padStart(2, '0')}</div>
            <div>
              <div class="ch-title">{ch.title}</div>
              <div class="ch-sub">{ch.subtitle}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
