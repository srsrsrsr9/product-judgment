---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Fastchain — Writing about AI" activePage="fastchain">
  <div class="page-enter">
    <div class="section">
      <div class="section-header">
        <span class="section-num">03</span>
        <h2 class="section-title">Fastchain</h2>
      </div>
      <div class="fc-card">
        <div class="fc-title">Fastchain</div>
        <div class="fc-sub">A Substack publication exploring AI &mdash; how it's built, how it's applied, and what product builders need to know to use it responsibly.</div>
        <a class="fc-link" href="#">Read on Substack &rarr;</a>
      </div>
      <div class="d-ph" style="max-width: 640px; margin-top: 2rem;">
        <div class="d-ph-t">Recent Posts (RSS Feed)</div>
        Embed recent Fastchain posts here via Substack's RSS feed or oEmbed.
      </div>
    </div>
  </div>
</BaseLayout>
