---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Srinivas Vedantam — Product Leader, Builder, Writer" activePage="home">
  <div class="page-enter">
    <div class="hero">
      <div class="hero-label">Product Leader &middot; Builder &middot; Writer</div>
      <h1>I build things that <em>teach</em>, things that <em>heal</em>, and things that <em>talk back</em>.</h1>
      <p class="hero-sub">18 years of product leadership distilled into a book, four shipped products, and an ongoing conversation about building with AI responsibly.</p>
      <div class="hero-cards">
        <a class="hero-card" href="/book/">
          <div class="hero-card-icon">&#x1F4D6;</div>
          <div class="hero-card-title">The Book</div>
          <div class="hero-card-desc">10 chapters on building AI products</div>
        </a>
        <a class="hero-card" href="/products/">
          <div class="hero-card-icon">&#x1F6E0;</div>
          <div class="hero-card-title">Products</div>
          <div class="hero-card-desc">4 shipped products, end to end</div>
        </a>
        <a class="hero-card" href="/fastchain/">
          <div class="hero-card-icon">&#x26A1;</div>
          <div class="hero-card-title">Fastchain</div>
          <div class="hero-card-desc">Writing about AI on Substack</div>
        </a>
        <a class="hero-card" href="/about/">
          <div class="hero-card-icon">&#x1F464;</div>
          <div class="hero-card-title">About</div>
          <div class="hero-card-desc">18+ years in product</div>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
